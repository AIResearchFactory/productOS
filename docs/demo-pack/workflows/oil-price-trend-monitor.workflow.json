{
  "id": "wf_oil_price_trend_monitor",
  "project_id": "demo-productos",
  "name": "Oil Price Trend Monitor (Every 4 Hours)",
  "description": "Tracks crude oil trend, summarizes changes, identifies likely drivers from macro/geopolitics/supply-demand signals, and outputs an actionable brief.",
  "version": "1.0.0",
  "created": "2026-03-15T00:00:00Z",
  "updated": "2026-03-15T00:00:00Z",
  "schedule": {
    "enabled": true,
    "cron": "0 */4 * * *",
    "timezone": "Asia/Jerusalem"
  },
  "steps": [
    {
      "id": "step_input_market_context",
      "name": "Market Context Input",
      "step_type": "input",
      "depends_on": [],
      "config": {
        "source_type": "TextInput",
        "source_value": "Track Brent and WTI trends in the last 24h and 7d. Identify likely causes of movement: OPEC+ actions, inventory data, macro rates/inflation, geopolitical events, shipping disruptions, refinery demand, USD strength.",
        "output_file": "oil-context.md"
      }
    },
    {
      "id": "step_input_sources",
      "name": "Sources List",
      "step_type": "input",
      "depends_on": [],
      "config": {
        "source_type": "TextInput",
        "source_value": "EIA Weekly Petroleum Status Report\nOPEC announcements\nICE Brent market summary\nCME WTI market summary\nReuters energy feed\nBloomberg energy headlines\nMajor shipping/chokepoint updates",
        "output_file": "oil-sources.md"
      }
    },
    {
      "id": "step_iterate_sources",
      "name": "Review Sources in Parallel",
      "step_type": "iteration",
      "depends_on": [
        "step_input_sources"
      ],
      "config": {
        "items_source": "{{steps.step_input_sources.output}}",
        "parallel": true,
        "output_pattern": "oil-source-{{item}}.md"
      }
    },
    {
      "id": "step_collect_signals",
      "name": "Collect Price + Driver Signals",
      "step_type": "agent",
      "depends_on": [
        "step_input_market_context",
        "step_iterate_sources"
      ],
      "config": {
        "skill_id": "market_research_analyst",
        "input_files": [
          "oil-context.md",
          "oil-source-{{item}}.md"
        ],
        "parameters": {
          "task_description": "Extract: price direction (up/down/flat), magnitude, confidence, and explicit evidence links/quotes for each source item."
        },
        "output_file": "oil-signals-{{item}}.md"
      }
    },
    {
      "id": "step_synthesize_trend",
      "name": "Synthesize Trend + Causes",
      "step_type": "synthesis",
      "depends_on": [
        "step_collect_signals"
      ],
      "config": {
        "input_files": [
          "oil-signals-*.md"
        ],
        "output_file": "oil-trend-summary.md",
        "parameters": {
          "format": "markdown",
          "sections": [
            "Headline trend (4h / 24h / 7d)",
            "Top likely causes ranked by confidence",
            "Bullish vs bearish drivers",
            "What changed since last run",
            "Risks / uncertainty",
            "Actionable watchlist for next 4 hours"
          ]
        }
      }
    },
    {
      "id": "step_publish_brief",
      "name": "Publish Monitoring Brief",
      "step_type": "agent",
      "depends_on": [
        "step_synthesize_trend"
      ],
      "config": {
        "skill_id": "report_writer",
        "input_files": [
          "oil-trend-summary.md"
        ],
        "parameters": {
          "task_description": "Produce an executive brief in plain English with: TL;DR, key numbers, causes, and next-check triggers."
        },
        "output_file": "oil-brief-latest.md"
      }
    }
  ]
}
