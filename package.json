{
  "name": "productos",
  "version": "0.2.7",
  "private": false,
  "type": "module",
  "bin": {
    "productos": "./bin/productos.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "src/",
    "src-tauri/src/",
    "src-tauri/Cargo.toml",
    "src-tauri/Cargo.lock",
    "vite.config.ts",
    "tsconfig.json",
    "tsconfig.node.json",
    "index.html",
    "postcss.config.cjs",
    "tailwind.config.ts",
    "package.json"
  ],
  "scripts": {
    "postinstall": "node ./bin/postinstall.mjs",
    "dev": "concurrently -k -p \"[{name}]\" -n \"vite,server\" -c \"cyan.bold,green.bold\" \"vite\" \"npm run dev:server\"",
    "start": "npm run build && npm run dev:server",
    "dev:server": "cd src-tauri && cargo run --bin productos-server",
    "dev:server:ci": "node scripts/run-dev-server-ci.mjs",
    "build": "tsc && vite build && cd src-tauri && cargo build --bin productos-server --release",
    "test:unit:optimizer": "node --test tests/workflow-optimizer.unit.test.mjs",
    "test:integration:token-saver": "node --test tests/token-saver.integration.test.mjs",
    "test:guardrails": "node --test tests/artifact-quality.test.mjs",
    "test:starter-pack": "node --test tests/starter-pack.test.mjs",
    "test:mvp:personal-pm": "node --test tests/artifact-quality.test.mjs tests/starter-pack.test.mjs tests/token-saver.integration.test.mjs",
    "test:channels": "node --test tests/channel-settings.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ci": "node scripts/run-e2e-ci.mjs",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "generate-credits": "node scripts/generate-credits.js",
    "stop": "node scripts/stop-dev.js"
  },
  "dependencies": {
    "@radix-ui/react-context-menu": "2.2.16",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-icons": "1.3.2",
    "@radix-ui/react-menubar": "1.1.16",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-toast": "1.2.15",
    "@tiptap/extension-bubble-menu": "3.22.1",
    "@tiptap/extension-floating-menu": "3.22.1",
    "@tiptap/extension-link": "3.22.1",
    "@tiptap/extension-placeholder": "3.22.1",
    "@tiptap/extension-table": "3.22.1",
    "@tiptap/extension-table-cell": "3.22.1",
    "@tiptap/extension-table-header": "3.22.1",
    "@tiptap/extension-table-row": "3.22.1",
    "@tiptap/markdown": "3.22.1",
    "@tiptap/pm": "3.22.1",
    "@tiptap/react": "3.22.1",
    "@tiptap/starter-kit": "3.22.1",
    "@tiptap/suggestion": "3.22.1",
    "@types/tippy.js": "6.3.0",
    "@xyflow/react": "12.10.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "framer-motion": "12.29.0",
    "lucide-react": "0.263.1",
    "papaparse": "5.5.3",
    "pptxgenjs": "4.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "tailwind-merge": "3.4.0",
    "tippy.js": "6.3.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "0.5.19",
    "@types/node": "25.5.0",
    "@types/papaparse": "5.5.2",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.4.16",
    "baseline-browser-mapping": "2.9.13",
    "concurrently": "^9.2.1",
    "esbuild": "0.27.4",
    "postcss": "8.4.31",
    "start-server-and-test": "2.1.2",
    "tailwindcss": "3.3.5",
    "typescript": "5.2.2",
    "vite": "^8.0.8",
    "vite-plugin-pwa": "^1.2.0",
    "webdriverio": "9.27.0"
  },
  "overrides": {
    "vite": "$vite",
    "sourcemap-codec": "npm:@jridgewell/sourcemap-codec@^1.4.15",
    "glob": "^13.0.6",
    "source-map": "npm:source-map@0.7.6",
    "encoding-sniffer": "^1.0.2",
    "magic-string": "^0.30.0",
    "workbox-build": {
      "source-map": "npm:source-map@0.7.6",
      "glob": "^13.0.6"
    }
  }
}
